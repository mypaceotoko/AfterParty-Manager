# データベース設定
# SQLite ファイルの場所（デフォルトは prisma/dev.db）
DATABASE_URL="file:./prisma/dev.db"

# AI プロバイダ設定（どちらか一方を設定してください）
# 未設定の場合はモックメッセージが生成されます

# Anthropic API (Claude) を使用する場合
# ANTHROPIC_API_KEY="sk-ant-..."

# OpenAI 互換 API を使用する場合
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1"  # 省略時はこのURLが使用されます
